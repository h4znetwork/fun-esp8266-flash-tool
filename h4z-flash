#!/bin/bash

# Setup warna biar CLI lebih interaktif
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

echo -e "${GREEN}=== H4Z ESP8266 Flasher ===${NC}"

# Cek apakah user masukin nama file
if [ -z "$1" ]; then
  echo -e "${RED}Error: Nama file .ino belum dimasukin bro!${NC}"
  echo -e "Cara pakai: ${YELLOW}h4z-flash <nama_file.ino> [port]${NC}"
  echo -e "Contoh: ${YELLOW}h4z-flash servo_wifi.ino /dev/ttyUSB0${NC}"
  exit 1
fi

FILE=$1
# Default port ke ttyUSB0 kalau port nggak diisi
PORT=${2:-/dev/ttyUSB0} 
FQBN="esp8266:esp8266:nodemcuv2"

echo -e "⚙️  Lagi compile ${YELLOW}$FILE${NC} ..."
arduino-cli compile --fqbn $FQBN "$FILE"

# Cek apakah compile sukses ($? nyimpen status exit dari command sebelumnya)
if [ $? -eq 0 ]; then
  echo -e "${GREEN}✅ Compile sukses!${NC}"
  echo -e "🚀 Flashing ke port ${YELLOW}$PORT${NC} ..."
  
  arduino-cli upload -p $PORT --fqbn $FQBN "$FILE"
  
  if [ $? -eq 0 ]; then
    echo -e "${GREEN}🎉 Mantap! Code berhasil masuk ke ESP8266.${NC}"
  else
    echo -e "${RED}❌ Flashing gagal. Cek kabel atau pastiin port USB lu bener ($PORT).${NC}"
  fi
else
  echo -e "${RED}❌ Compile gagal. Cek lagi kodenya bro, mungkin ada typo.${NC}"
fi
